# CRM Agent Environment Variables

# Server
PORT=3200
NODE_ENV=development

# Security
AGENT_SECRET=change_this_to_random_32_char_secret

# Heffl CRM API
HEFFL_API_KEY=your_heffl_api_key_here
HEFFL_BASE_URL=https://api.heffl.com/api/v1

# OpenRouter LLM
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=anthropic/claude-3-haiku-20240307

# Session & Timeout
SESSION_TTL_MINUTES=30
CONFIRMATION_TIMEOUT_SECONDS=300

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10
